---
import Layout from "@/layouts/Layout.astro";
import { IconArrowLeft } from "@tabler/icons-svelte";
---

<Layout pageTitle="Add playlist">
	<main
		class="mx-auto px-5 sm:px-6 lg:px-8 pb-16 pt-4 lg:pt-6 max-w-480 w-full">

		<div class="max-w-2xl mx-auto">

		<header class="route-hero mb-10">
			<a
				href="/"
				class="self-start inline-flex items-center gap-1.5 text-sm text-fg-3 hover:text-fg focus-visible:text-fg transition-colors min-h-10 -ml-1 mb-2">
				<IconArrowLeft class="h-4 w-4" /> <span data-i18n="common.back">Back</span>
			</a>
			<h1
				id="page-title"
				data-i18n="login.title.add"
				class="route-hero__title">
				Add a playlist
			</h1>
			<p
				id="page-subtitle"
				data-i18n="login.subtitle"
				class="route-hero__sub">
				Connect an Xtream provider, or paste an M3U/M3U8 playlist URL.
			</p>
		</header>


		<!-- Method picker: clean segmented control -->
		<div
			role="tablist"
			aria-label="Playlist type" data-i18n-attr="aria-label:aria.playlistType"
			class="grid grid-cols-2 gap-1 p-1 rounded-xl border border-line bg-surface mb-10 max-w-md">
			<button
				id="tab-xtream"
				type="button"
				role="tab"
				class="flex flex-col items-center justify-center text-center px-3 py-2 rounded-lg min-h-12 transition-colors disabled:cursor-not-allowed disabled:opacity-40">
				<span data-i18n="login.tab.subscription" class="text-sm font-medium leading-tight">
					I have a subscription
				</span>
				<span
					data-i18n="login.tab.subscription.sub"
					class="mt-0.5 text-label font-medium uppercase tracking-wider opacity-70">
					Xtream Codes
				</span>
			</button>
			<button
				id="tab-m3u"
				type="button"
				role="tab"
				class="flex flex-col items-center justify-center text-center px-3 py-2 rounded-lg min-h-12 transition-colors disabled:cursor-not-allowed disabled:opacity-40">
				<span data-i18n="login.tab.url" class="text-sm font-medium leading-tight">
					I have a playlist URL
				</span>
				<span
					data-i18n="login.tab.url.sub"
					class="mt-0.5 text-label font-medium uppercase tracking-wider opacity-70">
					M3U / M3U8
				</span>
			</button>
		</div>

		<form
			id="playlist-form"
			class="flex flex-col gap-6"
			autocomplete="off">
			<label class="flex flex-col gap-2">
				<span
					data-i18n="login.field.title"
					class="text-xs font-semibold tracking-wider uppercase text-fg-3">
					Title
				</span>
				<input
					id="title"
					type="text"
					placeholder="e.g. Living room TV"
					data-i18n-attr="placeholder:login.field.title.placeholder"
					class="field-input"
				/>
				<span data-i18n="login.field.title.helper" class="text-xs text-fg-3 leading-relaxed"
					>Optional name for this playlist.</span
				>
			</label>

			<!-- Xtream fields -->
			<div id="xtream-fields" class="flex flex-col gap-6">
				<label class="flex flex-col gap-2">
					<span
						data-i18n="login.field.serverUrl"
						class="text-xs font-semibold tracking-wider uppercase text-fg-3">
						Server URL
					</span>
					<input
						id="serverUrl"
						type="text"
						placeholder="http://example.com:8080"
						class="field-input"
					/>
					<span data-i18n="login.field.serverUrl.helper" class="text-xs text-fg-3 leading-relaxed">
						Paste a full player_api.php URL to auto-fill the fields below, or enter just the
						server URL and fill in username and password yourself.
					</span>
				</label>

				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
					<label class="flex flex-col gap-2">
						<span
							data-i18n="login.field.username"
							class="text-xs font-semibold tracking-wider uppercase text-fg-3">
							Username
						</span>
						<input
							id="username"
							type="text"
							autocapitalize="off"
							spellcheck="false"
							class="field-input"
						/>
					</label>
					<label class="flex flex-col gap-2">
						<span
							data-i18n="login.field.password"
							class="text-xs font-semibold tracking-wider uppercase text-fg-3">
							Password
						</span>
						<input
							id="password"
							type="password"
							class="field-input"
						/>
					</label>
				</div>
			</div>

			<!-- M3U fields -->
			<div id="m3u-fields" class="hidden flex-col gap-6">
				<label class="flex flex-col gap-2">
					<span
						data-i18n="login.field.playlistUrl"
						class="text-xs font-semibold tracking-wider uppercase text-fg-3">
						Playlist URL
					</span>
					<input
						id="m3uUrl"
						type="text"
						placeholder="https://example.com/playlist.m3u8"
						class="field-input"
					/>
					<span data-i18n="login.field.playlistUrl.helper" class="text-xs text-fg-3 leading-relaxed">
						Must end with .m3u or .m3u8.
					</span>
				</label>
			</div>

			<!-- Status -->
			<div
				id="status"
				class="hidden items-start gap-2.5 rounded-xl border px-3.5 py-2.5 text-sm leading-relaxed">
			</div>

			<!-- Actions -->
			<div
				class="flex flex-wrap gap-2 pt-2 mt-2 border-t border-line">
				<button
					id="testBtn"
					type="button"
					data-i18n="login.action.test"
					class="btn">
					Test connection
				</button>
				<button
					id="saveBtn"
					type="submit"
					data-i18n="login.action.save"
					class="btn-primary ml-auto">
					Save and continue
				</button>
			</div>
		</form>

		<p data-i18n="login.fineprint" class="mt-12 text-xs text-fg-3 leading-relaxed">
			This app does not provide any content. Use any
			Xtream-compatible IPTV subscription, or paste any M3U/M3U8 playlist
			URL. Public test playlists are available at iptv-org.github.io/iptv.
		</p>

		</div>
	</main>
</Layout>

<script>
	import {
		addEntry,
		updateEntry,
		getEntries,
		parseXtreamUrl,
		testXtreamConnection,
		testM3UUrl,
		isTauri,
	} from "@/scripts/lib/creds.js";
	import { t } from "@/scripts/lib/i18n.js";

	const $ = (id) => /** @type {any} */ (document.getElementById(id));

	const tabXtream = $("tab-xtream");
	const tabM3u = $("tab-m3u");
	const xFields = $("xtream-fields");
	const mFields = $("m3u-fields");
	const titleEl = $("title");
	const serverEl = $("serverUrl");
	const userEl = $("username");
	const passEl = $("password");
	const m3uEl = $("m3uUrl");
	const statusEl = $("status");
	const testBtn = $("testBtn");
	const saveBtn = $("saveBtn");
	const pageTitle = $("page-title");
	const pageSubtitle = $("page-subtitle");

	const params = new URLSearchParams(location.search);
	const editingId = params.get("edit");
	const isDemo = params.get("demo") === "1";
	const DEMO_M3U_URL = "https://iptv-org.github.io/iptv/index.m3u";
	let editing = null;
	let mode = "xtream";

	const ACTIVE_TAB =
		"bg-accent-soft text-accent ring-1 ring-accent/30";
	const IDLE_TAB = "text-fg-2 hover:text-fg";

	function setMode(next) {
		const prev = mode;
		mode = next;
		const isX = next === "xtream";
		xFields.classList.toggle("hidden", !isX);
		xFields.classList.toggle("flex", isX);
		mFields.classList.toggle("hidden", isX);
		mFields.classList.toggle("flex", !isX);

		if (prev && prev !== next) {
			const shown = isX ? xFields : mFields;
			shown.classList.remove("fade-section");
			void shown.offsetWidth;
			shown.classList.add("fade-section");
		}

		applyTabStyles(tabXtream, isX);
		applyTabStyles(tabM3u, !isX);

		testBtn.classList.remove("hidden");
		clearStatus();
	}

	function applyTabStyles(btn, active) {
		btn.className =
			"flex flex-col items-center justify-center text-center px-3 py-2 rounded-lg min-h-12 transition-colors disabled:cursor-not-allowed disabled:opacity-40 " +
			(active ? ACTIVE_TAB : IDLE_TAB);
	}

	tabXtream.addEventListener("click", () => {
		if (editing) return;
		setMode("xtream");
	});
	tabM3u.addEventListener("click", () => {
		if (editing) return;
		setMode("m3u");
	});

	serverEl.addEventListener("input", () => {
		const parsed = parseXtreamUrl(serverEl.value.trim());
		if (parsed) {
			serverEl.value = parsed.serverUrl;
			if (!userEl.value) userEl.value = parsed.username;
			if (!passEl.value) passEl.value = parsed.password;
			showStatus("info", t("login.status.credentialsExtracted"));
		}
	});

	function clearStatus() {
		statusEl.classList.add("hidden");
		statusEl.classList.remove("flex");
		statusEl.innerHTML = "";
	}

	function showStatus(kind, message) {
		const wasHidden = statusEl.classList.contains("hidden");
		statusEl.classList.remove("hidden");
		statusEl.classList.add("flex");
		// Reset palette classes, then apply.
		statusEl.className =
			"flex items-start gap-2.5 rounded-xl border px-3.5 py-2.5 text-sm leading-relaxed ";
		const palette = {
			info: "border-accent/30 bg-accent-soft text-accent",
			active: "border-ok/30 bg-ok/10 text-ok",
			expired: "border-warn/30 bg-warn/10 text-warn",
			inactive: "border-warn/30 bg-warn/10 text-warn",
			unavailable: "border-bad/30 bg-bad/10 text-bad",
			busy: "border-line bg-surface text-fg-2",
		};
		statusEl.className += palette[kind] || palette.info;
		const dot = `<span aria-hidden="true" class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-current shrink-0"></span>`;
		statusEl.innerHTML = `${dot}<span>${escapeText(message)}</span>`;
		if (wasHidden) {
			statusEl.classList.remove("status-enter");
			void statusEl.offsetWidth;
			statusEl.classList.add("status-enter");
		}
	}

	function escapeText(s) {
		const d = document.createElement("div");
		d.textContent = s;
		return d.innerHTML;
	}

	function isPrivateHost(host) {
		return (
			/^10\./.test(host) ||
			/^192\.168\./.test(host) ||
			/^172\.(1[6-9]|2\d|3[01])\./.test(host) ||
			host === "localhost" ||
			host.endsWith(".local")
		);
	}

	function privateHostHint(rawUrl) {
		try {
			const u = new URL(rawUrl);
			if (!isTauri && isPrivateHost(u.hostname)) {
				return " " + t("login.status.privateHostHint");
			}
		} catch {}
		return "";
	}

	testBtn.addEventListener("click", async () => {
		testBtn.disabled = true;
		try {
			if (mode === "xtream") {
				const serverUrl = serverEl.value.trim();
				const username = userEl.value.trim();
				const password = passEl.value.trim();
				if (!serverUrl || !username || !password) {
					showStatus(
						"unavailable",
						t("login.status.fillFields")
					);
					return;
				}
				showStatus("busy", t("login.status.testing"));
				const r = await testXtreamConnection({
					serverUrl,
					username,
					password,
				});
				const exp = r.expDate
					? t("login.status.expiresOn", { date: new Date(r.expDate).toLocaleDateString() })
					: "";
				switch (r.status) {
					case "active":
						showStatus("active", t("login.status.connected") + exp);
						break;
					case "expired":
						showStatus("expired", t("login.status.expired") + exp);
						break;
					case "inactive":
						showStatus("inactive", t("login.status.inactive") + exp);
						break;
					default:
						showStatus(
							"unavailable",
							t("login.status.serverUnreachable") + (r.message ? ` - ${r.message}` : ".") + privateHostHint(serverUrl)
						);
				}
			} else {
				const url = m3uEl.value.trim();
				if (!url) {
					showStatus("unavailable", t("login.status.enterM3uUrl"));
					return;
				}
				showStatus("busy", t("login.status.fetching"));
				const r = await testM3UUrl(url);
				if (r.status === "active") {
					const n = r.count || 0;
					showStatus(
						"active",
						t("login.status.playlistOk") + (n ? t("login.status.playlistEntries", { count: n.toLocaleString() }) : ".")
					);
				} else {
					showStatus(
						"unavailable",
						t("login.status.playlistFetchFailed") + (r.message ? ` - ${r.message}` : ".") + privateHostHint(url)
					);
				}
			}
		} finally {
			testBtn.disabled = false;
		}
	});

	$("playlist-form").addEventListener("submit", async (e) => {
		e.preventDefault();
		saveBtn.disabled = true;
		try {
			if (mode === "xtream") {
				const serverUrl = serverEl.value.trim();
				const username = userEl.value.trim();
				const password = passEl.value.trim();
				if (!serverUrl || !username || !password) {
					showStatus(
						"unavailable",
						t("login.status.allRequired")
					);
					return;
				}
				if (!/^https?:\/\/[^\s]+$/i.test(serverUrl)) {
					showStatus(
						"unavailable",
						t("login.status.serverUrlScheme")
					);
					return;
				}
				const patch = {
					type: "xtream",
					title: titleEl.value.trim() || "",
					serverUrl,
					username,
					password,
				};
				if (editing) await updateEntry(editing._id, patch);
				else await addEntry(patch);
			} else {
				const url = m3uEl.value.trim();
				if (!/^https?:\/\/[^\s]+\.m3u8?(\?.*)?$/i.test(url)) {
					showStatus(
						"unavailable",
						t("login.status.m3uScheme")
					);
					return;
				}
				const patch = {
					type: "m3u",
					title: titleEl.value.trim() || "",
					url,
				};
				if (editing) await updateEntry(editing._id, patch);
				else await addEntry(patch);
			}
			location.href = editing ? "/" : "/livetv";
		} finally {
			saveBtn.disabled = false;
		}
	});

	// ---- Boot: prefill for editing, or default to "add Xtream" ----
	if (editingId) {
		const entries = await getEntries();
		editing = entries.find((e) => e._id === editingId) || null;
	}
	if (editing) {
		pageTitle.removeAttribute("data-i18n");
		pageTitle.textContent = t("login.title.edit");
		pageSubtitle.removeAttribute("data-i18n");
		pageSubtitle.textContent = t("login.subtitle.edit", { title: editing.title });
		saveBtn.removeAttribute("data-i18n");
		saveBtn.textContent = t("login.action.saveEdit");
		tabXtream.disabled = editing.type !== "xtream";
		tabM3u.disabled = editing.type !== "m3u";
		setMode(editing.type);
		titleEl.value = editing.title || "";
		if (editing.type === "xtream") {
			serverEl.value = editing.serverUrl || "";
			userEl.value = editing.username || "";
			passEl.value = editing.password || "";
		} else {
			m3uEl.value = editing.url || "";
		}
	} else if (isDemo) {
		pageTitle.setAttribute("data-i18n", "login.title.demo");
		pageTitle.textContent = t("login.title.demo");
		pageSubtitle.setAttribute("data-i18n", "login.subtitle.demo");
		pageSubtitle.textContent = t("login.subtitle.demo");
		setMode("m3u");
		titleEl.value = t("login.demo.title");
		m3uEl.value = DEMO_M3U_URL;
		showStatus("info", t("login.status.demoPrefilled"));
	} else {
		setMode("xtream");
	}
</script>
