# Copy this file to `.env.screenshots` (gitignored) and fill in real creds.
# Used by `pnpm screenshots` to pre-seed the app so screenshots show real data.

# URL of the running app (default: http://localhost:4321 from `pnpm dev`)
SCREENSHOT_URL=http://localhost:4321

# Pick ONE of the two modes below.

# --- Xtream provider ---
XT_TYPE=xtream
XT_SERVER_URL=http://your-provider.example.com:8080
XT_USERNAME=your_username
XT_PASSWORD=your_password

# --- Direct M3U / M3U8 playlist URL ---
# XT_TYPE=m3u
# XT_M3U_URL=https://example.com/playlist.m3u8
